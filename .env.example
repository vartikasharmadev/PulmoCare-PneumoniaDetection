MONGODB_URI=mongodb://localhost:27017/pneumonia_fl
PORT=5000
# Include both localhost and 127.0.0.1 so the browser Origin always matches
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
MODEL_API_URL=http://127.0.0.1:8000/predict
# Optional: only for production build or when not using Vite proxy. Leave unset during `npm run dev`.
# VITE_API_URL=http://127.0.0.1:5000
#
# One-shot dev (from repo root, after: npm install):
#   npm run dev
# Starts Python (8000), Express (5000), and Vite (5173) together.
#
# --- Railway (Express service; set in dashboard Variables) ---
# PORT is set automatically by Railway — do not set manually.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/pneumonia_fl
# MODEL_API_URL=https://YOUR-PYTHON-SERVICE.up.railway.app/predict
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

